# 必填：你的 NewAPI / OneAPI 站点根地址，不要以 / 结尾
# Vercel 部署时请在 Project Settings -> Environment Variables 中配置同名变量
UPSTREAM_API_BASE=https://your-newapi.example.com

# 可选：如果你的令牌查询接口不是 /api/usage/token/，可以直接指定完整接口地址
# UPSTREAM_TOKEN_USAGE_URL=https://your-newapi.example.com/api/usage/token/

# 可选：仅前端直连调试时使用。留空则浏览器请求同源 /api/usage/token
# VITE_API_BASE=https://your-newapi.example.com

# 可选：额度换算比例，默认 500000 quota = 1 USD
VITE_QUOTA_PER_USD=500000
