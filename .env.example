# =====================================================
# Check API Tool - 环境变量示例
# 复制为 .env 或 .env.local 后按需修改
# 部署到 Vercel 时，请在 Project Settings → Environment Variables 中配置同名变量
# =====================================================

# 上游 New API / One API 网关地址
# 支持两种写法：
# 1) 单个 URL（页面无 Tab）
#    REACT_APP_BASE_URL=https://api.example.com
# 2) 多站点 JSON 对象（页面以 Tab 形式切换）
REACT_APP_BASE_URL={"server1": "https://api.server1.com", "server2": "https://api.server2.com"}

# 是否展示令牌额度信息（true / false），默认 true
REACT_APP_SHOW_BALANCE=true

# 是否展示调用明细日志（true / false），默认 true
REACT_APP_SHOW_DETAIL=true

# 是否在导航栏显示 GitHub 图标（true / false）
REACT_APP_SHOW_ICONGITHUB=true
